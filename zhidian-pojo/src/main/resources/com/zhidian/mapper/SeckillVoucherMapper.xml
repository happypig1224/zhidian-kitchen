<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhidian.mapper.SeckillVoucherMapper">

    <resultMap id="BaseResultMap" type="com.zhidian.entity.SeckillVoucher">
            <id property="id" column="id" />
            <result property="voucherId" column="voucher_id" />
            <result property="title" column="title" />
            <result property="rules" column="rules" />
            <result property="payValue" column="pay_value" />
            <result property="actualValue" column="actual_value" />
            <result property="status" column="status" />
            <result property="stock" column="stock" />
            <result property="beginTime" column="begin_time" />
            <result property="endTime" column="end_time" />
            <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,voucher_id,title,rules,pay_value,actual_value,
        status,stock,begin_time,end_time,create_time
    </sql>
    <insert id="issueVoucher" parameterType="seckillVoucher" useGeneratedKeys="true" keyProperty="id">
        insert into seckill_voucher (voucher_id, title, rules, pay_value, actual_value, status, stock, begin_time, end_time, create_time)
        values (#{voucherId}, #{title}, #{rules}, #{payValue}, #{actualValue}, #{status}, #{stock}, #{beginTime}, #{endTime}, #{createTime})
    </insert>
</mapper>
